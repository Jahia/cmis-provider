JAHIA_VERSION=${JAHIA_VERSION:-LATEST}
JAHIA_IMAGE=${JAHIA_IMAGE:-jahia/jahia-ee-dev:8-SNAPSHOT}
TESTS_IMAGE=${TESTS_IMAGE:-jahia/cmis-provider:latest}
MODULE_ID=${MODULE_ID:-cmis-provider}
MANIFEST=${MANIFEST:-provisioning-manifest-build.yml}
JAHIA_URL=${JAHIA_URL:-http://localhost:8080}
JAHIA_HOST=${JAHIA_HOST:-jahia}
JAHIA_PORT=${JAHIA_PORT:-8080}
JAHIA_USERNAME=${JAHIA_USERNAME:-root}
JAHIA_PASSWORD=${JAHIA_PASSWORD:-root1234}
SUPER_USER_PASSWORD=${SUPER_USER_PASSWORD:-root1234}
JAHIA_USERNAME_TOOLS=${JAHIA_USERNAME_TOOLS:-root}
JAHIA_PASSWORD_TOOLS=${JAHIA_PASSWORD_TOOLS:-root1234}
NEXUS_USERNAME=${NEXUS_USERNAME:-NEXUS_USERNAME}
NEXUS_PASSWORD=${NEXUS_PASSWORD:-NEXUS_PASSWORD}
JAHIA_CLUSTER_ENABLED=${JAHIA_CLUSTER_ENABLED:-false}
TIMEZONE=${TIMEZONE:-America/Toronto}
JAHIA_LICENSE=${JAHIA_LICENSE:-""}
LDAP_TAG=${LDAP_TAG:-1.1.0}
ALFRESCO_URL=${ALFRESCO_URL:-http://localhost:9080}
SHARE_URL=${SHARE_URL:-http://localhost:9081}